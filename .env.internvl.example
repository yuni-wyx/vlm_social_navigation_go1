# Copy to `.env.internvl` for local use, then:
#   set -a; source .env.internvl; set +a
#   python vlm_wrapper.py

VLM_WRAPPER_HOST=0.0.0.0
VLM_WRAPPER_PORT=8000

VLM_BACKEND=remote_openai
VLM_BASE_URL=http://GPU_SERVER_HOST:8000/v1
VLM_MODEL=OpenGVLab/InternVL3_5-14B-HF
VLM_API_KEY=
VLM_TIMEOUT=120
VLM_DEBUG=true

VLM_ROUTE_STYLE=openai_chat
VLM_CHAT_PATH=/chat/completions

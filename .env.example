# VLM wrapper service bind
VLM_WRAPPER_HOST=0.0.0.0
VLM_WRAPPER_PORT=8000

# Backend selection
# local: current Mac-hosted workflow
# remote_openai: remote OpenAI-compatible server such as vLLM or LMDeploy
# remote_custom: remote custom JSON API
VLM_BACKEND=local

# Common backend config
VLM_BASE_URL=http://localhost:1234/v1
VLM_MODEL=local-model
VLM_API_KEY=
VLM_TIMEOUT=60
VLM_DEBUG=false

# Request formatting
# openai_chat: POST chat/completions with OpenAI-compatible vision payload
# custom: POST a small custom JSON payload {"model","prompt","images_base64"}
VLM_ROUTE_STYLE=openai_chat
VLM_CHAT_PATH=/chat/completions

# Backward-compatible aliases still supported by vlm_wrapper.py:
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=local-model
# LM_STUDIO_TIMEOUT=60

# Example: remote InternVL/Qwen served through an OpenAI-compatible server
# VLM_BACKEND=remote_openai
# VLM_BASE_URL=http://GPU_SERVER_HOST:8000/v1
# VLM_MODEL=OpenGVLab/InternVL3-8B
# VLM_ROUTE_STYLE=openai_chat
# VLM_CHAT_PATH=/chat/completions

# Example: remote custom FastAPI wrapper
# VLM_BACKEND=remote_custom
# VLM_BASE_URL=http://GPU_SERVER_HOST:9000
# VLM_MODEL=Qwen2.5-VL-7B-Instruct
# VLM_ROUTE_STYLE=custom
# VLM_CHAT_PATH=/infer
